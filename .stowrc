# GNU Stow configuration file
# This configures stow to manage dotfiles from the packages/ directory

# Target directory (where symlinks will be created)
--target=$HOME

# Source directory (where packages are stored)
--dir=packages

# Use dotfiles mode (transforms dot- prefix to . in target)
--dotfiles

# Default to verbose output for better feedback
--verbose

# Simulate mode for safe testing (comment out for actual use)
# --simulate
EOF < /dev/null