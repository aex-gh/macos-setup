# Dev Brewfile - Development environment tools
# Programming languages, build tools, containers, cloud tools, and development IDEs

# Additional Taps
tap "oven-sh/bun"
tap "mongodb/brew"

# Version Control & Git Tools
brew "git-lfs"                # Git Large File Storage
brew "gh"                     # GitHub CLI
brew "git-delta"              # Better git diffs
brew "lazygit"                # Terminal git UI
brew "git-flow"               # Git branching model
brew "pre-commit"             # Git hook framework

# Programming Languages
brew "python@3.12"            # Python 3.12
brew "python@3.11"            # Python 3.11
brew "pyenv"                  # Python version management
brew "node"                   # Node.js
brew "nvm"                    # Node version manager
brew "bun"                    # Fast JavaScript runtime
brew "deno"                   # Secure JavaScript runtime
brew "go"                     # Go programming language
brew "rust"                   # Rust programming language
brew "ruby"                   # Ruby programming language
brew "rbenv"                  # Ruby version manager
brew "swift"                  # Swift programming language
brew "lua"                    # Lua programming language

# Build Tools
brew "cmake"                  # Cross-platform build system
brew "make"                   # GNU make
brew "autoconf"               # Configure script builder
brew "automake"               # Makefile generator
brew "pkg-config"             # Library configuration
brew "libtool"                # Generic library support
brew "meson"                  # Build system
brew "ninja"                  # Small build system
brew "bazel"                  # Build and test tool
brew "sccache"                # Shared compilation cache

# Container & Virtualization
brew "dive"                   # Docker image explorer

# Cloud Tools
brew "awscli"                 # AWS CLI
brew "azure-cli"              # Azure CLI
brew "google-cloud-sdk"       # Google Cloud SDK
brew "flyctl"                 # Fly.io CLI
brew "hcloud"                 # Hetzner Cloud CLI

# Infrastructure as Code

# Database Tools
brew "postgresql@17"          # PostgreSQL database
brew "mysql"                  # MySQL database
brew "redis"                  # Redis key-value store
brew "sqlite"                 # SQLite database
brew "mongodb-community"      # MongoDB database
brew "cassandra"              # Cassandra database
brew "memcached"              # Memory caching system
brew "etcd"                   # Distributed key-value store

# API Development
brew "httpie"                 # HTTP client
brew "grpcurl"                # gRPC client
brew "protobuf"               # Protocol buffers
brew "openapi-generator"      # OpenAPI code generator
brew "mockserver"             # Mock HTTP server

# Development Casks
cask "visual-studio-code"     # Code editor
cask "zed"                    # Fast code editor
cask "jetbrains-toolbox"      # JetBrains IDE manager
cask "coteditor"              # Plain text editor

# Terminal & Shell
cask "warp"                   # Modern terminal
cask "ghostty"                # Terminal emulator

# Development Tools
cask "github-desktop"         # GitHub GUI
cask "sourcetree"             # Git GUI

# Database GUIs
cask "dbeaver-community"      # Universal database tool
cask "sequel-ace"             # MySQL/MariaDB management
cask "mongodb-compass"        # MongoDB GUI
cask "redis-insight"          # Redis GUI

# API Tools
cask "bruno"                  # API client

# Container Management
cask "orbstack"               # Fast Docker/Linux environment

# iOS Development
cask "xcode"                  # Apple IDE
cask "xcodes"                 # Xcode version manager
cask "sf-symbols"             # Apple symbol browser

# Other Development Tools
cask "json-viewer"            # JSON visualization
